# =============================================================================
# Protein Platform — Environment Variable Reference
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR | CRITICAL
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false        # Set true only in local development

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-me-generate-a-long-random-secret-key
JWT_SECRET=change-me-generate-a-separate-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=protein_db
POSTGRES_USER=protein_user
POSTGRES_PASSWORD=change-me-strong-password

# Convenience DSN (built from the individual vars above)
DATABASE_URL=postgresql+asyncpg://protein_user:change-me-strong-password@localhost:5432/protein_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://:@localhost:6379/0

# -----------------------------------------------------------------------------
# Neo4j (Knowledge Graph)
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j-password
NEO4J_DATABASE=neo4j

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672/
CELERY_RESULT_BACKEND=redis://:@localhost:6379/1
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC

# -----------------------------------------------------------------------------
# External Bioinformatics APIs
# -----------------------------------------------------------------------------
UNIPROT_API_URL=https://rest.uniprot.org/uniprotkb
ALPHAFOLD_API_URL=https://alphafold.ebi.ac.uk/api
PUBCHEM_API_URL=https://pubchem.ncbi.nlm.nih.gov/rest/pug
PDB_API_URL=https://data.rcsb.org/rest/v1
CHEMBL_API_URL=https://www.ebi.ac.uk/chembl/api/data
NCBI_ENTREZ_EMAIL=your-email@example.com   # Required by NCBI policy
NCBI_API_KEY=                              # Optional — raises rate limit

# -----------------------------------------------------------------------------
# Frontend (Next.js — NEXT_PUBLIC_ vars are exposed to the browser)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Protein Platform
NEXT_PUBLIC_APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Monitoring & Observability (optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_METRICS_ENABLED=false
